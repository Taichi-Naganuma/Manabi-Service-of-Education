@if (IsSpeaker && IsListener)
{
    <span class="badge me-1" style="background-color:#0d6efd">🗣️ Speaker</span>
    <span class="badge" style="background-color:#198754">👂 Listener</span>
}
else if (IsSpeaker)
{
    <span class="badge" style="background-color:#0d6efd">🗣️ Speaker</span>
}
else
{
    <span class="badge" style="background-color:#198754">👂 Listener</span>
}

@code {
    [Parameter] public bool IsSpeaker { get; set; }
    [Parameter] public bool IsListener { get; set; } = true;
}
