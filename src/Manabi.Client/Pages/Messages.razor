@page "/messages"
@attribute [Authorize]
@inject ChatApiService ChatApi
@inject NavigationManager Nav

<PageTitle>メッセージ — Mananect</PageTitle>

<h2 class="mb-4">メッセージ</h2>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (conversations.Count == 0)
{
    <div class="text-center mt-5 text-muted">
        <p>まだメッセージのやり取りがありません。</p>
        <a class="btn btn-outline-primary mt-2" href="/members">メンバーを探す</a>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var conv in conversations)
        {
            <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3"
                    @onclick="() => GoToChat(conv.OtherUserId)">

                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                     style="width:48px;height:48px">
                    @conv.OtherUserDisplayName[..1]
                </div>

                <div class="flex-grow-1 text-start overflow-hidden">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong>@conv.OtherUserDisplayName</strong>
                        <small class="text-muted">@FormatTime(conv.LastMessageAt)</small>
                    </div>
                    <div class="text-muted text-truncate small">@conv.LastMessage</div>
                </div>

                @if (conv.UnreadCount > 0)
                {
                    <span class="badge bg-primary rounded-pill">@conv.UnreadCount</span>
                }
            </button>
        }
    </div>
}

@code {
    private List<ConversationResponse> conversations = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        conversations = await ChatApi.GetConversationsAsync();
        isLoading = false;
    }

    private void GoToChat(string userId) => Nav.NavigateTo("/chat/" + userId);

    private string FormatTime(DateTime dt)
    {
        var local = dt.ToLocalTime();
        return DateTime.Now.Date == local.Date
            ? local.ToString("HH:mm")
            : local.ToString("M/d");
    }
}
