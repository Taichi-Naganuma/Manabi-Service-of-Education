@page "/members"
@page "/teachers"
@attribute [Authorize]
@inject TeacherApiService TeacherApi
@inject NavigationManager Nav

<PageTitle>メンバーを探す — Mananect</PageTitle>

<h2 class="mb-4">メンバーを探す</h2>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <input class="form-control" placeholder="経験・テーマで検索 (例: 起業, 失恋)" @bind="skillFilter" @bind:event="oninput" />
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="sortBy">
            <option value="">並び替え</option>
            <option value="rating">評価順</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" @onclick="SearchAsync">検索</button>
    </div>
</div>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (members.Count == 0)
{
    <div class="text-center mt-5 text-muted">
        <p>まだメンバーが登録されていません。</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var member in members)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            @if (member.AvatarUrl is not null)
                            {
                                <img src="@member.AvatarUrl" class="rounded-circle me-2" width="48" height="48" alt="avatar" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-secondary me-2 d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width:48px;height:48px">
                                    @member.DisplayName[..1]
                                </div>
                            }
                            <div>
                                <h5 class="mb-0">@member.DisplayName</h5>
                                @if (member.AverageRating > 0)
                                {
                                    <small class="text-warning">★ @member.AverageRating.ToString("F1") (@(member.TotalReviews)件)</small>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(member.Bio))
                        {
                            <p class="card-text text-muted small" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">@member.Bio</p>
                        }

                        @if (member.Categories.Count > 0)
                        {
                            <div class="mb-2">
                                @foreach (var cat in member.Categories.Take(4))
                                {
                                    <span class="badge bg-primary-subtle text-primary-emphasis me-1">@cat</span>
                                }
                            </div>
                        }

                        @if (member.Skills.Count > 0)
                        {
                            <div class="mb-2">
                                @foreach (var skill in member.Skills.Take(3))
                                {
                                    <span class="badge bg-light text-dark me-1 border">@skill</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-footer text-end">
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => GoToProfile(member.UserId)">
                            プロフィールを見る
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<TeacherProfileResponse> members = [];
    private bool isLoading = true;
    private string skillFilter = "";
    private string sortBy = "";

    protected override async Task OnInitializedAsync() => await SearchAsync();

    private async Task SearchAsync()
    {
        isLoading = true;
        members = await TeacherApi.GetTeachersAsync(
            skill: string.IsNullOrEmpty(skillFilter) ? null : skillFilter,
            sortBy: string.IsNullOrEmpty(sortBy) ? null : sortBy);
        isLoading = false;
    }

    private void GoToProfile(string userId) => Nav.NavigateTo("/users/" + userId);
}
