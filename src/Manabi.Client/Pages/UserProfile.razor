@page "/users/{UserId}"
@attribute [Authorize]
@inject UserApiService UserApi
@inject NavigationManager Nav
@inject HttpClient Http
@inject AnalyticsService Analytics

<PageTitle>@(profile?.DisplayName ?? "プロフィール") — Mananect</PageTitle>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (profile is null)
{
    <p class="text-danger">ユーザーが見つかりませんでした。</p>
}
else if (profile.IsDeleted)
{
    <div class="text-center py-5" style="color:#aaa;">
        <div style="font-size:3rem;margin-bottom:1rem;">🌿</div>
        <h5 style="color:#999;font-weight:500;">このユーザーは今はいないようです</h5>
        <p class="mt-2" style="font-size:0.9rem;">
            あなたとの大切なやり取りは、届いた手紙の中に残っています。
        </p>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center position-relative">
                    <div class="position-absolute top-0 end-0 m-2">
                        <ContentMenu TargetUserId="@UserId"
                                     TargetType="profile"
                                     TargetId="@UserId"
                                     OnUserBlocked="@OnUserBlocked" />
                    </div>
                    <div class="rounded-circle bg-secondary mx-auto mb-3 d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:96px;height:96px;font-size:2rem">
                        @profile.DisplayName[..1]
                    </div>
                    <h4 class="mb-1">@profile.DisplayName</h4>
                    <div class="mt-2">
                        <RoleBadge IsSpeaker="@profile.IsTeacher" IsListener="@(!profile.IsTeacher)" />
                    </div>
                </div>
            </div>

            @if (profile.IsTeacher)
            {
                <button class="btn btn-primary w-100"
                        @onclick="OpenSessionModal">
                    この経験を聞く
                </button>
            }
        </div>

        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(profile.Bio))
            {
                <h5 class="mb-3">自己紹介・話せる経験</h5>
                @foreach (var part in profile.Bio.Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
                {
                    <p class="mb-3" style="white-space: pre-wrap">@part</p>
                }
            }

            @if (profile.Categories is { Count: > 0 })
            {
                <h6 class="mb-2">カテゴリー</h6>
                <div class="mb-4">
                    @foreach (var cat in profile.Categories)
                    {
                        <span class="badge bg-primary me-1 mb-1 fs-6">@cat</span>
                    }
                </div>
            }

            @if (profile.Skills is { Count: > 0 })
            {
                <h6 class="mb-2">話せるテーマ</h6>
                <div class="mb-4">
                    @foreach (var skill in profile.Skills)
                    {
                        <span class="badge bg-light text-dark me-1 mb-1 border fs-6">@skill</span>
                    }
                </div>
            }

            <hr />
            <h6 class="mb-3">🌿 この人への手紙</h6>
            @if (publicLetters.Count > 0)
            {
                @foreach (var letter in visibleLetters)
                {
                    <div class="mb-3 p-3 rounded" style="background:#f0fdf4;border:1px solid #bbf7d0;">
                        <p class="mb-1 fst-italic lh-base">「@letter.Content」</p>
                        <p class="mb-0 text-muted small">— <a href="/users/@letter.FromUserId">@letter.FromUserName</a> / @letter.CreatedAt.ToString("yyyy-MM-dd")</p>
                    </div>
                }
                @if (publicLetters.Count > 3 && !showAllLetters)
                {
                    <button class="btn btn-link btn-sm ps-0" @onclick="() => showAllLetters = true">
                        もっと見る (@(publicLetters.Count - 3)件)
                    </button>
                }
            }
            else
            {
                <p class="text-muted small fst-italic mb-0">まだ手紙はありません</p>
            }
        </div>
    </div>
}

<SessionRequestModal UserId="@UserId" UserName="@(profile?.DisplayName ?? "")"
                     IsOpen="@isModalOpen"
                     OnSendAsync="@HandleSessionRequest"
                     OnCancelAsync="@CloseSessionModal" />

@code {
    [Parameter] public string UserId { get; set; } = "";

    private UserProfileResponse? profile;
    private bool isLoading = true;
    private bool isModalOpen = false;
    private bool showAllLetters = false;

    private List<PublicLetterDto> publicLetters = [];
    private List<PublicLetterDto> visibleLetters => showAllLetters ? publicLetters : publicLetters.Take(3).ToList();

    protected override async Task OnInitializedAsync()
    {
        var profileTask = UserApi.GetUserAsync(UserId);
        var lettersTask = Http.GetFromJsonAsync<List<PublicLetterDto>>($"/api/letters/public/{UserId}?limit=10");
        await Task.WhenAll(profileTask, lettersTask);

        profile = profileTask.Result;
        publicLetters = lettersTask.Result ?? [];
        isLoading = false;
        if (profile is not null)
            Analytics.Track("member_profile_viewed", $"/users/{UserId}", UserId);
    }

    private void OpenSessionModal() => isModalOpen = true;
    private void CloseSessionModal() => isModalOpen = false;

    private Task HandleSessionRequest((string category, string message) request)
    {
        CloseSessionModal();
        var messageEncoded = Uri.EscapeDataString(request.message);
        Nav.NavigateTo($"/chat/{UserId}?initialMessage={messageEncoded}");
        return Task.CompletedTask;
    }

    private void OnUserBlocked() => Nav.NavigateTo("/members");

    private record PublicLetterDto(Guid Id, string FromUserName, string FromUserId, string Content, DateTime CreatedAt);
}
