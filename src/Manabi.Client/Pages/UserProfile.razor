@page "/users/{UserId}"
@attribute [Authorize]
@inject UserApiService UserApi
@inject NavigationManager Nav

<PageTitle>@(profile?.DisplayName ?? "プロフィール") — Manabi</PageTitle>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (profile is null)
{
    <p class="text-danger">ユーザーが見つかりませんでした。</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-secondary mx-auto mb-3 d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:96px;height:96px;font-size:2rem">
                        @profile.DisplayName[..1]
                    </div>
                    <h4>@profile.DisplayName</h4>
                    @if (!string.IsNullOrEmpty(profile.Bio))
                    {
                        <p class="text-muted small">@profile.Bio</p>
                    }
                </div>

                @if (profile.IsTeacher && profile.Rate30Min.HasValue)
                {
                    <div class="card-footer">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted small">30分</span>
                            <strong>¥@profile.Rate30Min.Value.ToString("N0")</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">60分</span>
                            <strong>¥@(profile.Rate60Min?.ToString("N0") ?? "—")</strong>
                        </div>
                    </div>
                }
            </div>

            <button class="btn btn-primary w-100"
                    @onclick="GoToChat">
                メッセージを送る
            </button>
        </div>

        <div class="col-md-8">
            @if (profile.Skills is { Count: > 0 })
            {
                <h5 class="mb-3">スキル</h5>
                <div class="mb-4">
                    @foreach (var skill in profile.Skills)
                    {
                        <span class="badge bg-primary me-1 mb-1 fs-6">@skill</span>
                    }
                </div>
            }

            @if (profile.IsTeacher && profile.AverageRating > 0)
            {
                <p class="text-warning">★ @profile.AverageRating?.ToString("F1") （@(profile.TotalReviews)件のレビュー）</p>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string UserId { get; set; } = "";

    private UserProfileResponse? profile;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        profile = await UserApi.GetUserAsync(UserId);
        isLoading = false;
    }

    private void GoToChat() => Nav.NavigateTo("/chat/" + UserId);
}
