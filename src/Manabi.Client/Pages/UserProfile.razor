@page "/users/{UserId}"
@attribute [Authorize]
@inject UserApiService UserApi
@inject NavigationManager Nav

<PageTitle>@(profile?.DisplayName ?? "プロフィール") — Mananect</PageTitle>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (profile is null)
{
    <p class="text-danger">ユーザーが見つかりませんでした。</p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-secondary mx-auto mb-3 d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:96px;height:96px;font-size:2rem">
                        @profile.DisplayName[..1]
                    </div>
                    <h4 class="mb-1">@profile.DisplayName</h4>
                    <div class="mt-2">
                        <RoleBadge IsSpeaker="@profile.IsTeacher" IsListener="@(!profile.IsTeacher)" />
                    </div>
                </div>
            </div>

            @if (profile.IsTeacher)
            {
                <button class="btn btn-primary w-100"
                        @onclick="OpenSessionModal">
                    この経験を聞く
                </button>
            }
        </div>

        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(profile.Bio))
            {
                <h5 class="mb-3">自己紹介・話せる経験</h5>
                <p class="mb-4" style="white-space: pre-wrap">@profile.Bio</p>
            }

            @if (profile.Categories is { Count: > 0 })
            {
                <h6 class="mb-2">カテゴリー</h6>
                <div class="mb-4">
                    @foreach (var cat in profile.Categories)
                    {
                        <span class="badge bg-primary me-1 mb-1 fs-6">@cat</span>
                    }
                </div>
            }

            @if (profile.Skills is { Count: > 0 })
            {
                <h6 class="mb-2">話せるテーマ</h6>
                <div class="mb-4">
                    @foreach (var skill in profile.Skills)
                    {
                        <span class="badge bg-light text-dark me-1 mb-1 border fs-6">@skill</span>
                    }
                </div>
            }

            @if (profile.IsTeacher && profile.AverageRating > 0)
            {
                <p class="text-warning">★ @profile.AverageRating?.ToString("F1") （@(profile.TotalReviews)件のレビュー）</p>
            }
        </div>
    </div>
}

<SessionRequestModal UserId="@UserId" UserName="@(profile?.DisplayName ?? "")"
                     IsOpen="@isModalOpen"
                     OnSendAsync="@HandleSessionRequest"
                     OnCancelAsync="@CloseSessionModal" />

@code {
    [Parameter] public string UserId { get; set; } = "";

    private UserProfileResponse? profile;
    private bool isLoading = true;
    private bool isModalOpen = false;

    protected override async Task OnInitializedAsync()
    {
        profile = await UserApi.GetUserAsync(UserId);
        isLoading = false;
    }

    private void OpenSessionModal() => isModalOpen = true;
    private void CloseSessionModal() => isModalOpen = false;

    private async Task HandleSessionRequest((string category, string message) request)
    {
        CloseSessionModal();
        var messageEncoded = Uri.EscapeDataString(request.message);
        Nav.NavigateTo($"/chat/{UserId}?initialMessage={messageEncoded}");
    }
}
