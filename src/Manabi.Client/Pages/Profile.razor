@page "/profile"
@attribute [Authorize]
@inject TeacherApiService TeacherApi

<PageTitle>マイページ — Manabi</PageTitle>

<h2 class="mb-4">マイページ</h2>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (!hasProfile)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-3">スキルプロフィールを作成</h5>
            <p class="text-muted">スキルと料金を登録すると、メンバー一覧に表示されるようになります。</p>

            <EditForm Model="createModel" OnValidSubmit="CreateProfileAsync">
                <DataAnnotationsValidator />
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">30分レート (円)</label>
                        <InputNumber class="form-control" @bind-Value="createModel.Rate30Min" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">60分レート (円)</label>
                        <InputNumber class="form-control" @bind-Value="createModel.Rate60Min" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">スキル（カンマ区切り）</label>
                    <InputText class="form-control" placeholder="Python, Django, SQL" @bind-Value="skillsInput" />
                </div>
                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }
                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                    @(isSaving ? "保存中..." : "プロフィールを作成")
                </button>
            </EditForm>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-3">スキルプロフィール編集</h5>

            <EditForm Model="updateModel" OnValidSubmit="UpdateProfileAsync">
                <DataAnnotationsValidator />
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">30分レート (円)</label>
                        <InputNumber class="form-control" TValue="int?" @bind-Value="updateModel.Rate30Min" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">60分レート (円)</label>
                        <InputNumber class="form-control" TValue="int?" @bind-Value="updateModel.Rate60Min" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">スキル（カンマ区切り）</label>
                    <InputText class="form-control" placeholder="Python, Django, SQL" @bind-Value="skillsInput" />
                </div>
                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }
                @if (successMessage is not null)
                {
                    <div class="alert alert-success">@successMessage</div>
                }
                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                    @(isSaving ? "保存中..." : "保存")
                </button>
            </EditForm>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool hasProfile = false;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;
    private string skillsInput = "";

    private readonly CreateTeacherProfileRequest createModel = new();
    private readonly UpdateTeacherProfileRequest updateModel = new();

    protected override async Task OnInitializedAsync()
    {
        var profile = await TeacherApi.GetMyProfileAsync();
        if (profile is not null)
        {
            hasProfile = true;
            updateModel.Rate30Min = profile.Rate30Min;
            updateModel.Rate60Min = profile.Rate60Min;
            updateModel.Skills = profile.Skills;
            skillsInput = string.Join(", ", profile.Skills);
        }
        isLoading = false;
    }

    private async Task CreateProfileAsync()
    {
        isSaving = true;
        errorMessage = null;
        createModel.Skills = skillsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        var ok = await TeacherApi.CreateProfileAsync(createModel);
        if (ok)
        {
            hasProfile = true;
            updateModel.Rate30Min = createModel.Rate30Min;
            updateModel.Rate60Min = createModel.Rate60Min;
            updateModel.Skills = createModel.Skills;
            successMessage = "プロフィールを作成しました。";
        }
        else
        {
            errorMessage = "作成に失敗しました。";
        }
        isSaving = false;
    }

    private async Task UpdateProfileAsync()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;
        updateModel.Skills = skillsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        var ok = await TeacherApi.UpdateProfileAsync(updateModel);
        if (ok) successMessage = "保存しました。";
        else errorMessage = "保存に失敗しました。";
        isSaving = false;
    }
}
