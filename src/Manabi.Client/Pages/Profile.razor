@page "/profile"
@attribute [Authorize]
@inject TeacherApiService TeacherApi
@inject MatteringApiService MatteringApi
@inject StoryApiService StoryApi
@inject HttpClient Http
@inject AnalyticsService Analytics
@inject NavigationManager Nav

<PageTitle>マイページ — Mananect</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <h2 class="mb-0">マイページ</h2>
    @if (!isLoading)
    {
        <RoleBadge IsSpeaker="@hasProfile" IsListener="@(!hasProfile)" />
    }
</div>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else
{
    @if (stats is not null)
    {
        <div class="mb-4 p-3 rounded mattering-counter" role="button" tabindex="0"
             style="background:#f0fdf4;border:1px solid #bbf7d0;cursor:pointer;"
             @onclick='() => Nav.NavigateTo("/my-letters")'>
            <p class="mb-1 text-success fw-semibold">🌿 @stats.UniquePartners 人にあなたの話が届いた</p>
            <p class="mb-0 text-success fw-semibold">🌿 @stats.LetterCount 通の手紙を受け取った</p>
            <p class="mb-0 text-success small mt-1">→ 受け取った手紙を見る</p>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-3">@(hasProfile ? "プロフィール編集" : "プロフィールを作成")</h5>
            @if (!hasProfile)
            {
                <p class="text-muted">あなたの経験を登録すると、メンバー一覧に表示されるようになります。</p>
            }

            <EditForm Model="model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <div class="mb-4">
                    <p class="fw-bold mb-3">あなたの経験を教えてください</p>

                    <div class="mb-3">
                        <label class="form-label">Q1. あなたが乗り越えた経験を一つ教えてください <span class="text-danger">*</span></label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="bioQ1"
                                       placeholder="例：30歳で起業して2年で失敗しました。その時に気づいたことが今も生きています。" />
                        @if (q1Error is not null)
                        {
                            <div class="text-danger small mt-1">@q1Error</div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Q2. その時に気づいたことは？ <span class="text-muted small">（任意）</span></label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="bioQ2"
                                       placeholder="例：失敗は終わりではなく、方向転換のサインだと気づきました。" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Q3. 同じ経験をしている人に伝えたいことは？ <span class="text-muted small">（任意）</span></label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="bioQ3"
                                       placeholder="例：一人で抱え込まないでほしい。話すだけで楽になることがあります。" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">話せるテーマ（カンマ区切り）</label>
                    <div class="form-text mb-2">具体的な経験のキーワード。検索で見つけてもらいやすくなります。</div>
                    <InputText class="form-control" placeholder="例：起業, 失恋, 持病との向き合い方, 転職" @bind-Value="skillsInput" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">カテゴリー（複数選択可）</label>
                    <div>
                        @foreach (var cat in AvailableCategories)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" id="cat-@cat"
                                       checked="@selectedCategories.Contains(cat)"
                                       @onchange="e => ToggleCategory(cat, (bool)e.Value!)" />
                                <label class="form-check-label" for="cat-@cat">@cat</label>
                            </div>
                        }
                    </div>
                </div>

                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }
                @if (successMessage is not null)
                {
                    <div class="alert alert-success">@successMessage</div>
                }
                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                    @(isSaving ? "保存中..." : "保存")
                </button>
            </EditForm>
        </div>
    </div>

    @if (hasProfile)
    {
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="card-title mb-0">Story Cards <span class="text-muted small fw-normal">(@myStories.Count / 5本)</span></h5>
                    @if (myStories.Count < 5)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="OpenNewStory">＋ 新しい経験を書く</button>
                    }
                </div>

                @if (showStoryForm)
                {
                    <div class="border rounded p-3 mb-3 bg-light">
                        <div class="mb-2">
                            <input class="form-control form-control-sm" placeholder="タイトル（任意）" @bind="storyTitle" />
                        </div>
                        <div class="mb-2">
                            <textarea class="form-control form-control-sm" rows="4"
                                      placeholder="あなたの経験を一節として書いてください（50字以上）"
                                      @bind="storyContent"></textarea>
                        </div>
                        <div class="mb-2">
                            <select class="form-select form-select-sm" @bind="storyCategory">
                                <option value="">カテゴリー（任意）</option>
                                @foreach (var cat in AvailableCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                        @if (storyError is not null)
                        {
                            <div class="text-danger small mb-2">@storyError</div>
                        }
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary btn-sm" @onclick="SaveStory" disabled="@isSavingStory">
                                @(isSavingStory ? "保存中..." : "公開する")
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelStory">キャンセル</button>
                        </div>
                    </div>
                }

                @if (myStories.Count == 0 && !showStoryForm)
                {
                    <p class="text-muted small">まだ Story Cards がありません。「＋ 新しい経験を書く」から追加できます。</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var story in myStories)
                        {
                            <div class="col-12">
                                <div class="border rounded p-3 position-relative">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div>
                                            @if (!string.IsNullOrEmpty(story.Title))
                                            {
                                                <p class="mb-0 fw-bold small text-primary">【@story.Title】</p>
                                            }
                                            @if (!string.IsNullOrEmpty(story.Category))
                                            {
                                                <span class="badge bg-primary-subtle text-primary-emphasis me-1">@story.Category</span>
                                            }
                                        </div>
                                        <div class="d-flex gap-2 align-items-center">
                                            <span class="badge @(story.IsPublished ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") small">
                                                @(story.IsPublished ? "公開中" : "下書き")
                                            </span>
                                            <button class="btn btn-outline-danger btn-sm py-0 px-1" style="font-size:12px;"
                                                    @onclick="() => DeleteStory(story)">削除</button>
                                        </div>
                                    </div>
                                    <p class="mb-0 small lh-base" style="white-space:pre-wrap;">@GetExcerpt(story.Content)</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="card-title mb-3">メール通知設定</h5>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="notifyLetter"
                       checked="@notifyOnLetter"
                       @onchange="e => UpdateNotifyPref(nameof(notifyOnLetter), (bool)e.Value!)" />
                <label class="form-check-label" for="notifyLetter">手紙が届いたとき</label>
            </div>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="notifyRequest"
                       checked="@notifyOnRequest"
                       @onchange="e => UpdateNotifyPref(nameof(notifyOnRequest), (bool)e.Value!)" />
                <label class="form-check-label" for="notifyRequest">セッションリクエストが届いたとき</label>
            </div>
            @if (notifySaved)
            {
                <p class="text-success small mt-1">保存しました</p>
            }
        </div>
    </div>
}

@code {
    private static readonly string[] AvailableCategories =
    {
        "恋愛", "人間関係", "仕事", "起業", "健康", "家族", "学び", "日常"
    };

    private bool isLoading = true;
    private bool hasProfile = false;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;
    private string? q1Error;
    private string skillsInput = "";
    private string bioQ1 = "";
    private string bioQ2 = "";
    private string bioQ3 = "";
    private HashSet<string> selectedCategories = new();
    private MatteringStats? stats;
    private List<StoryEditDto> myStories = [];
    private bool notifyOnLetter = true;
    private bool notifyOnRequest = true;
    private bool notifySaved = false;
    private bool showStoryForm = false;
    private bool isSavingStory = false;
    private string storyTitle = "";
    private string storyContent = "";
    private string storyCategory = "";
    private string? storyError;

    private readonly UpdateTeacherProfileRequest model = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profileTask = TeacherApi.GetMyProfileAsync();
            var statsTask = MatteringApi.GetStatsAsync();
            var storiesTask = StoryApi.GetMyStoriesAsync();
            var notifTask = Http.GetFromJsonAsync<NotifPref>("/api/notifications/preferences");
            await Task.WhenAll(profileTask, statsTask, storiesTask, notifTask);

            stats = statsTask.Result;
            myStories = storiesTask.Result;
            if (notifTask.Result is { } np)
            {
                notifyOnLetter = np.NotifyOnLetterReceived;
                notifyOnRequest = np.NotifyOnSessionRequest;
            }
            var profile = profileTask.Result;
            if (profile is not null)
            {
                hasProfile = true;
                skillsInput = string.Join(", ", profile.Skills);
                selectedCategories = new HashSet<string>(profile.Categories);
                ParseBioToPrompts(profile.Bio);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"プロフィールの取得に失敗しました：{ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenNewStory()
    {
        storyTitle = "";
        storyContent = "";
        storyCategory = "";
        storyError = null;
        showStoryForm = true;
    }

    private void CancelStory()
    {
        showStoryForm = false;
        storyError = null;
    }

    private async Task SaveStory()
    {
        if (storyContent.Length < 50)
        {
            storyError = "本文は50文字以上で書いてください。";
            return;
        }
        isSavingStory = true;
        storyError = null;
        var ok = await StoryApi.CreateAsync(new CreateStoryRequest(
            storyContent,
            string.IsNullOrWhiteSpace(storyTitle) ? null : storyTitle,
            string.IsNullOrWhiteSpace(storyCategory) ? null : storyCategory,
            Publish: true));
        if (ok)
        {
            showStoryForm = false;
            myStories = await StoryApi.GetMyStoriesAsync();
        }
        else
        {
            storyError = "保存に失敗しました。";
        }
        isSavingStory = false;
    }

    private async Task DeleteStory(StoryEditDto story)
    {
        var ok = await StoryApi.DeleteAsync(story.Id);
        if (ok) myStories.Remove(story);
    }

    private static string GetExcerpt(string content, int max = 120)
        => content.Length > max ? content[..max] + "…" : content;

    private void ParseBioToPrompts(string bio)
    {
        // Bio を改行2つで区切って3つのQ&Aに分割。旧形式はQ1にまとめてプリフィル。
        var parts = bio.Split("\n\n", 3, StringSplitOptions.None);
        bioQ1 = parts.Length > 0 ? parts[0] : "";
        bioQ2 = parts.Length > 1 ? parts[1] : "";
        bioQ3 = parts.Length > 2 ? parts[2] : "";
    }

    private string BuildBioFromPrompts()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(bioQ1)) parts.Add(bioQ1.Trim());
        if (!string.IsNullOrWhiteSpace(bioQ2)) parts.Add(bioQ2.Trim());
        if (!string.IsNullOrWhiteSpace(bioQ3)) parts.Add(bioQ3.Trim());
        return string.Join("\n\n", parts);
    }

    private void ToggleCategory(string cat, bool isChecked)
    {
        if (isChecked) selectedCategories.Add(cat);
        else selectedCategories.Remove(cat);
    }

    private async Task SubmitAsync()
    {
        q1Error = null;
        if (string.IsNullOrWhiteSpace(bioQ1))
        {
            q1Error = "Q1は必須です。乗り越えた経験を教えてください。";
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        var bio = BuildBioFromPrompts();
        var skills = skillsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (hasProfile)
        {
            model.Skills = skills;
            model.Categories = selectedCategories.ToList();
            model.Bio = bio;
            var ok = await TeacherApi.UpdateProfileAsync(model);
            if (ok) successMessage = "保存しました。";
            else errorMessage = "保存に失敗しました。";
        }
        else
        {
            var createReq = new CreateTeacherProfileRequest
            {
                Skills = skills.Count > 0 ? skills : new List<string> { "経験" },
                Categories = selectedCategories.ToList(),
                Bio = bio
            };
            var ok = await TeacherApi.CreateProfileAsync(createReq);
            if (ok)
            {
                hasProfile = true;
                successMessage = "プロフィールを作成しました。";
                Analytics.Track("profile_created", "/profile");
            }
            else
            {
                errorMessage = "作成に失敗しました。";
            }
        }
        isSaving = false;
    }

    private async Task UpdateNotifyPref(string field, bool value)
    {
        if (field == nameof(notifyOnLetter)) notifyOnLetter = value;
        else notifyOnRequest = value;

        await Http.PutAsJsonAsync("/api/notifications/preferences", new
        {
            NotifyOnLetterReceived = notifyOnLetter,
            NotifyOnSessionRequest = notifyOnRequest
        });
        notifySaved = true;
        await Task.Delay(2000);
        notifySaved = false;
        StateHasChanged();
    }

    private record NotifPref(bool NotifyOnLetterReceived, bool NotifyOnSessionRequest);
}
