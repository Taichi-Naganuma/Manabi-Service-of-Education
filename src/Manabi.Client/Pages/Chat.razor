@page "/chat/{RecipientId}"
@attribute [Authorize]
@implements IAsyncDisposable
@inject ChatApiService ChatApi
@inject ChatHubService HubService
@inject UserApiService UserApi
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject AnalyticsService Analytics

<PageTitle>チャット — Mananect</PageTitle>

<div class="d-flex flex-column" style="height: calc(100vh - 120px)">
    <div class="border-bottom pb-2 mb-2 d-flex align-items-center gap-2">
        <a href="/users/@RecipientId" class="text-decoration-none text-dark fw-bold flex-grow-1">@recipientName</a>
        <button class="btn btn-outline-secondary btn-sm"
                @onclick="OpenLetterModal">✉️ 手紙を書く</button>
        <button class="btn btn-outline-danger btn-sm"
                @onclick="EndSession">セッションを終える</button>
    </div>

    <div class="flex-grow-1 overflow-auto mb-2" @ref="messageContainer">
        @foreach (var msg in messages)
        {
            @if (msg.IsSystemMessage)
            {
                <div class="text-center text-muted small my-3">
                    <span class="px-3 py-1 rounded-pill" style="background:#f1f5f9;border:1px solid #e2e8f0;">
                        @msg.Content
                    </span>
                </div>
            }
            else if (msg.IsSenderDeleted)
            {
                <div class="d-flex justify-content-start mb-2">
                    <div class="p-2 rounded border" style="max-width:70%;background:#f8f8f8;color:#999;">
                        <div style="white-space:pre-wrap;">@msg.Content</div>
                        <small>退会したユーザー · @msg.SentAt.ToLocalTime().ToString("HH:mm")</small>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex @(msg.IsOwn ? "justify-content-end" : "justify-content-start") mb-2">
                    <div class="p-2 rounded @(msg.IsOwn ? "bg-primary text-white" : "bg-light border")"
                         style="max-width: 70%">
                        <div>@msg.Content</div>
                        <small class="@(msg.IsOwn ? "text-white-50" : "text-muted")">
                            @msg.SentAt.ToLocalTime().ToString("HH:mm")
                        </small>
                    </div>
                </div>
            }
        }
    </div>

    <div class="d-flex gap-2">
        <input class="form-control" placeholder="メッセージを入力..."
               @bind="inputText" @bind:event="oninput"
               @onkeydown="HandleKeyDown" />
        <button class="btn btn-primary" @onclick="SendAsync" disabled="@(string.IsNullOrWhiteSpace(inputText))">
            送信
        </button>
    </div>
</div>

<SessionStartModal IsOpen="@showSessionStart"
                   PartnerName="@recipientName"
                   Category="@sessionCategory"
                   IsListener="@isListener"
                   OnConfirmAsync="@ConfirmSessionStart" />

<WitnessLetterModal IsOpen="@showLetterModal"
                    RecipientId="@RecipientId"
                    RecipientName="@recipientName"
                    PrefilledContent="@prefilledLetterContent"
                    OnCloseAsync="@CloseLetterModal"
                    OnSentAsync="@OnLetterSent" />

<ReflectionModal IsOpen="@showReflectionModal"
                 PartnerUserId="@RecipientId"
                 PartnerName="@recipientName"
                 IsListener="@isListener"
                 OnSkipAsync="@CloseReflection"
                 OnSendAsLetterAsync="@OnReflectionSendAsLetter"
                 OnSavedAsync="@CloseReflection" />

@code {
    [Parameter] public string RecipientId { get; set; } = "";
    [SupplyParameterFromQuery(Name = "initialMessage")]
    public string? InitialMessage { get; set; }

    private List<MessageResponse> messages = [];
    private string inputText = "";
    private string recipientName = "";
    private string? currentUserId;
    private ElementReference messageContainer;

    private bool showSessionStart = false;
    private bool showLetterModal = false;
    private bool showReflectionModal = false;
    private string prefilledLetterContent = "";
    private string sessionCategory = "経験";
    private bool isListener = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst("sub")?.Value;

        var user = await UserApi.GetUserAsync(RecipientId);
        recipientName = user?.DisplayName ?? RecipientId;

        messages = await ChatApi.GetMessagesAsync(RecipientId);
        if (currentUserId is not null)
        {
            foreach (var msg in messages)
                msg.IsOwn = msg.SenderId == currentUserId;
        }

        HubService.OnMessageReceived += OnMessageReceived;
        await HubService.ConnectAsync();
        await ChatApi.MarkReadAsync(RecipientId);

        // initialMessage は初回チャット時のみ送信
        if (!string.IsNullOrEmpty(InitialMessage) && messages.Count == 0)
        {
            inputText = InitialMessage;
            await SendAsync();
        }

        // SessionStartModal：初回のみ表示（localStorage で記録）
        var seenKey = $"chat_intro_seen_{RecipientId}";
        var seen = await JS.InvokeAsync<string?>("localStorage.getItem", seenKey);
        if (seen is null)
        {
            // 相手が Speaker（IsTeacher=true）なら自分は Listener として参加
            isListener = user?.IsTeacher ?? false;
            showSessionStart = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ScrollToBottomAsync();
    }

    private async Task ConfirmSessionStart()
    {
        showSessionStart = false;
        var seenKey = $"chat_intro_seen_{RecipientId}";
        await JS.InvokeVoidAsync("localStorage.setItem", seenKey, "1");

        // システムメッセージを送信
        await HubService.SendMessageAsync(RecipientId, "— ここからセッションがはじまりました —");
        Analytics.Track("session_started", "/chat", RecipientId);
    }

    private void OpenLetterModal()
    {
        prefilledLetterContent = "";
        showLetterModal = true;
    }

    private void CloseLetterModal() => showLetterModal = false;

    private async Task OnLetterSent()
    {
        showLetterModal = false;
        Analytics.Track("letter_sent", "/chat", RecipientId);
        // チャットタイムラインに手紙イベントを表示
        messages.Add(new MessageResponse
        {
            Content = "✉️ 手紙が届きました",
            SenderId = currentUserId ?? "",
            RecipientId = RecipientId,
            SentAt = DateTime.UtcNow,
            IsOwn = true,
            IsSystemMessage = true
        });
        StateHasChanged();
        await ScrollToBottomAsync();
    }

    private async Task EndSession()
    {
        await HubService.SendMessageAsync(RecipientId, "— セッションが終わりました —");
        Analytics.Track("session_ended", "/chat", RecipientId);
        showReflectionModal = true;
    }

    private void CloseReflection() => showReflectionModal = false;

    private void OnReflectionSendAsLetter(string text)
    {
        showReflectionModal = false;
        prefilledLetterContent = text;
        showLetterModal = true;
    }

    private void OnMessageReceived(MessageResponse msg)
    {
        if (msg.SenderId == RecipientId || msg.RecipientId == RecipientId)
        {
            msg.IsOwn = msg.SenderId == currentUserId;
            messages.Add(msg);
            InvokeAsync(async () =>
            {
                StateHasChanged();
                await ScrollToBottomAsync();
            });
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(inputText)) return;
        var content = inputText;
        inputText = "";
        await HubService.SendMessageAsync(RecipientId, content);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private async Task ScrollToBottomAsync()
    {
        try { await JS.InvokeVoidAsync("scrollToBottom", messageContainer); }
        catch { }
    }

    public ValueTask DisposeAsync()
    {
        HubService.OnMessageReceived -= OnMessageReceived;
        return ValueTask.CompletedTask;
    }
}
